# Agoras environment variables
# Copy to .env and fill in values for local development or unattended automation.
# See docs/reference/platform-arguments-envvars.rst for full reference.

# Optional: override default credential storage (~/.agoras)
# AGORAS_STORAGE_DIR=/path/to/agoras-data

# --- X (Twitter) - OAuth 1.0a ---
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_OAUTH_TOKEN=
TWITTER_OAUTH_SECRET=

# --- Facebook - OAuth 2.0 ---
FACEBOOK_APP_ID=
FACEBOOK_OBJECT_ID=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REFRESH_TOKEN=

# --- Instagram - OAuth 2.0 ---
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_OBJECT_ID=
INSTAGRAM_REFRESH_TOKEN=

# --- LinkedIn - OAuth 2.0 ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OBJECT_ID=
LINKEDIN_REFRESH_TOKEN=

# --- YouTube - OAuth 2.0 ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_KEYWORDS=

# --- TikTok - OAuth 2.0 ---
TIKTOK_USERNAME=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# --- Threads - OAuth 2.0 ---
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REFRESH_TOKEN=
THREADS_USER_ID=

# --- Discord - Bot Token ---
DISCORD_BOT_TOKEN=
DISCORD_SERVER_NAME=
DISCORD_CHANNEL_NAME=

# --- Telegram - Bot Token ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: seconds for large media uploads (default 300)
# TELEGRAM_MEDIA_WRITE_TIMEOUT=300

# --- WhatsApp - API Token ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_RECIPIENT=
# Optional: delete/share actions after post E2E tests
# WHATSAPP_MESSAGE_ID=
# Optional: template message E2E tests
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANGUAGE=en

# --- Google Sheets (schedule-run / feed automation) ---
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_NAME=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# --- RSS/Atom feed automation (feed-publish) ---
FEED_URL=
# Optional tuning for feed-publish and schedule-run
# MAX_COUNT=1
# POST_LOOKBACK=3600
# MAX_POST_AGE=365

# --- Common post content (optional overrides) ---
# STATUS_TEXT=
# STATUS_LINK=
# STATUS_IMAGE_URL_1=
# STATUS_IMAGE_URL_2=
# STATUS_IMAGE_URL_3=
# STATUS_IMAGE_URL_4=
# VIDEO_URL=
# VIDEO_TITLE=

# --- Live E2E / functional tests (tests/*.sh; not used in default CI) ---
# Export AGORAS_STORAGE_DIR=/tmp/agoras-test-e2e (never ~/.agoras) when running live tests.
# AGORAS_LIVE_E2E=1
# TEST_IMAGE_URL=
# TEST_VIDEO_URL=
# TEST_TIKTOK_IMAGE_URL=
# TEST_DISCORD_VIDEO_URL=
# FEED_PUBLISH_NETWORKS=x facebook linkedin
